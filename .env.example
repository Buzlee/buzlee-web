# Public origin for app.buzlee.com (no trailing slash). Used when NEXT_PUBLIC_AUTH_CALLBACK_URL is unset.
NEXT_PUBLIC_APP_ORIGIN=https://app.buzlee.com

# Optional: full auth callback URL (must match Supabase allowlist and Expo AUTH_CALLBACK_URL).
# NEXT_PUBLIC_AUTH_CALLBACK_URL=https://app.buzlee.com/auth/callback

# Custom scheme for “Open in app” (production app: buzlee; preview/dev builds may use buzlee.preview, etc.)
NEXT_PUBLIC_APP_SCHEME=buzlee

# Optional store URLs (defaults are set in src/shared/config/store-links.ts)
# NEXT_PUBLIC_IOS_APP_STORE_URL=
# NEXT_PUBLIC_ANDROID_PLAY_STORE_URL=

# Apple Universal Links — comma-separated TEAMID.bundleId (production bundle id: com.buzlee)
BUZLEE_APPLE_APP_IDS=

# Android App Links — package name and comma-separated SHA-256 cert fingerprints (Play Console / keytool)
BUZLEE_ANDROID_PACKAGE_NAME=com.buzlee
BUZLEE_ANDROID_SHA256=
